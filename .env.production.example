# ──────────────────────────────────────────────────────────────
# Auan-Auan-Platform — Production Environment Variables
#
# Copy to .env.production and fill in real values.
# NEVER commit .env.production to git.
#
# All variables below are validated by Zod at startup (env.ts).
# Missing required values will crash the API on boot.
# ──────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/auan_platform

# ─── Authentication (Customer — LINE Login) ──────────────────
# Minimum 32 characters. Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_AT_LEAST_32_CHARS

# ─── Authentication (Staff — Admin Dashboard) ───────────────
# Separate from customer JWT. Minimum 32 characters.
STAFF_JWT_SECRET=CHANGE_ME_GENERATE_AT_LEAST_32_CHARS
# Default: 8 (hours)
# STAFF_JWT_EXPIRY_HOURS=8
# Default: 30 (days)
# STAFF_SESSION_EXPIRY_DAYS=30

# ─── LINE Platform ────────────────────────────────────────────
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
# Optional. Falls back to LINE_CHANNEL_ACCESS_TOKEN if not set.
# LINE_MESSAGING_ACCESS_TOKEN=
# Optional. LIFF App ID (used for generating LIFF URLs).
# LIFF_ID=your-liff-id

# ─── LINE Webhook ─────────────────────────────────────────────
LINE_WEBHOOK_PATH=/api/v1/webhooks/line

# ─── Owner Authorization ──────────────────────────────────────
# Comma-separated LINE User IDs with Owner privileges.
OWNER_LINE_USER_IDS=line-user-id-1,line-user-id-2

# ─── Token Configuration ─────────────────────────────────────
# "bearer" | "cookie" | "both"
AUTH_TOKEN_SOURCE=bearer
# Default: 30 (days)
# REFRESH_TOKEN_EXPIRY_DAYS=30

# ─── JWT Cookie Configuration ────────────────────────────────
# Set to true when behind HTTPS (e.g. Cloudflare).
JWT_COOKIE_SECURE=true
JWT_COOKIE_HTTP_ONLY=true
JWT_COOKIE_SAME_SITE=lax
# JWT_COOKIE_DOMAIN=yourdomain.com
# JWT_COOKIE_PATH=/

# ─── File Upload ─────────────────────────────────────────────
# Default: ./uploads
# UPLOAD_PATH=./uploads
# Default: 5242880 (5MB)
# UPLOAD_MAX_SIZE=5242880

# ─── Staff Password Hashing ─────────────────────────────────
# Default: 12
# BCRYPT_SALT_ROUNDS=12

# ─── Pre-seeded Owner ───────────────────────────────────────
# Optional. If set, seed creates an owner staff account.
# OWNER_EMAIL=owner@example.com

# ─── Frontend URL (CORS + LIFF URL generation) ───────────────
FRONTEND_URL=https://yourdomain.com

# ─── Frontend Build (Vite) ───────────────────────────────────
# NOT needed when behind Nginx reverse proxy (default).
# The frontend calls /api/* which Nginx proxies to the backend.
# Set this ONLY if the API is on a different domain.
# VITE_API_BASE_URL=/api/v1
# VITE_LIFF_ID=your-liff-id

# ─── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Docker Compose ──────────────────────────────────────────
# These are read by docker-compose.prod.yml, NOT by the API.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=auan_platform
# NGINX_HTTP_PORT=80
