# ──────────────────────────────────────────────────────────────
# Auan-Auan-Platform — Development Environment Variables
#
# Copy to apps/api/.env for local development.
# ──────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auan_platform

# ─── Authentication (Customer — LINE Login) ──────────────────
# Minimum 32 characters
JWT_SECRET=dev-jwt-secret-must-be-at-least-32-characters

# ─── Authentication (Staff — Admin Dashboard) ───────────────
# Separate from customer JWT. Minimum 32 characters.
STAFF_JWT_SECRET=dev-staff-jwt-secret-must-be-at-least-32
# Default: 8 (hours)
# STAFF_JWT_EXPIRY_HOURS=8
# Default: 30 (days)
# STAFF_SESSION_EXPIRY_DAYS=30

# ─── LINE Platform ────────────────────────────────────────────
LINE_CHANNEL_ID=dev-line-channel-id
LINE_CHANNEL_SECRET=dev-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=dev-line-channel-access-token
# Optional. Falls back to LINE_CHANNEL_ACCESS_TOKEN if not set.
# LINE_MESSAGING_ACCESS_TOKEN=
# Optional. LIFF App ID (used for generating LIFF URLs).
# LIFF_ID=dev-liff-id

# ─── LINE Webhook ─────────────────────────────────────────────
LINE_WEBHOOK_PATH=/api/v1/webhooks/line

# ─── Owner Authorization ──────────────────────────────────────
# Comma-separated LINE User IDs with Owner privileges.
OWNER_LINE_USER_IDS=

# ─── Token Configuration ─────────────────────────────────────
# "bearer" | "cookie" | "both"
AUTH_TOKEN_SOURCE=bearer
# Default: 30 (days)
# REFRESH_TOKEN_EXPIRY_DAYS=30

# ─── JWT Cookie Configuration ────────────────────────────────
JWT_COOKIE_SECURE=false
JWT_COOKIE_HTTP_ONLY=true
JWT_COOKIE_SAME_SITE=lax
# JWT_COOKIE_DOMAIN=
JWT_COOKIE_PATH=/

# ─── File Upload ─────────────────────────────────────────────
# Default: ./uploads
# UPLOAD_PATH=./uploads
# Default: 5242880 (5MB)
# UPLOAD_MAX_SIZE=5242880

# ─── Staff Password Hashing ─────────────────────────────────
# Default: 12
# BCRYPT_SALT_ROUNDS=12

# ─── Pre-seeded Owner ───────────────────────────────────────
# Optional. If set, seed creates an owner staff account.
# OWNER_EMAIL=dev-owner@example.com

# ─── Frontend URL (CORS + LIFF URL generation) ───────────────
# FRONTEND_URL=

# ─── Frontend Build (Vite) ───────────────────────────────────
# VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_LIFF_ID=dev-liff-id

# ─── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Docker Compose ──────────────────────────────────────────
# These are read by docker-compose.prod.yml, NOT by the API.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=dev-postgres-password
POSTGRES_DB=auan_platform
# NGINX_HTTP_PORT=80
