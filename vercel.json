{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @auan/customer build && pnpm --filter @auan/admin build && rm -rf vercel-output && mkdir -p vercel-output/admin && cp -r apps/customer/dist/* vercel-output/ && cp -r apps/admin/dist/* vercel-output/admin/ && ls -la vercel-output/",
  "outputDirectory": "vercel-output",
  "rewrites": [
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/:match*", "destination": "/admin/index.html" },
    {
      "source": "/((?!assets|admin/assets|favicon|robots).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/admin/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
